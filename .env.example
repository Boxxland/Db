# ===== Discord Bot Token =====
# สร้างที่ https://discord.com/developers/applications
# Bot ใหม่แยกจาก Boxxland Auth Bot ตัวเดิม
DISCORD_TOKEN=your_mail_bot_token_here

# ===== Database (ใช้ Postgres ตัวเดียวกับ boxxland-db) =====
# เอา External Database URL ตัวเดียวกับที่ใช้ใน Boxxland Auth (.env บน Termux)
# ไม่ต้องสร้าง Postgres ใหม่ — Render free tier ให้แค่ 1 database/account
# (ตาราง mailnot_users, mailnot_messages จะถูกสร้างแยกอัตโนมัติ ไม่ชนกับตาราง users/sessions เดิม)
DATABASE_URL=postgresql://user:password@host:5432/dbname
